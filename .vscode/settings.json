{
    "python.analysis.extraPaths": [
        "./src"
    ],
    "python.testing.pytestArgs": [
        "tests"
    ],
    "python.testing.unittestEnabled": false,
    "python.testing.pytestEnabled": true,
    "cSpell.words": [
        "sloppatch"
    ],
    "customFileOrder.rules": {
        "src/sloppatch/patch": {
            "order": [
                "raw_parse.py",
                "raw_parse_data.py",
                "convert.py",
                "convert_data.py",
                "prepare_by_file.py",
                "prepare_by_file_data.py",
                "apply.py"
            ],
            "type": "manual"
        }
    },
    "todohighlight.keywords": [
        {
            "text": "WARN:",
            "backgroundColor": "rgb(255,122,42)",
            "color": "#ffffff",
            "overviewRulerColor": "rgba(255,122,42,0.8)"
        },
        {
            "text": "TODO:",
            "color": "#fff",
            "backgroundColor": "rgb(255,189,42)",
            "overviewRulerColor": "rgba(255,189,42,0.8)"
        },
        {
            "text": "FIXME:",
            "color": "#fff",
            "backgroundColor": "rgb(240,98,146)",
            "overviewRulerColor": "rgba(240,98,146,0.8)"
        }
    ]
}